# ==============================================
# Corpo Conectado — Variáveis de Ambiente
# ==============================================
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o .env no Git!

# --- Servidor ---
PORT=3000
NODE_ENV=development

# --- Autenticação ---
JWT_SECRET=secret_super_seguro_para_desenvolvimento

# --- Google Sheets ---
GOOGLE_SERVICE_ACCOUNT_EMAIL="seu-email-de-servico@seu-projeto.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE_AQUI\n-----END PRIVATE KEY-----"
GOOGLE_SHEET_ID="ID_DA_SUA_PLANILHA_(retirado_da_url)"

# --- Produção (Render) ---
# FRONTEND_URL=https://corpo-conectado.vercel.app
